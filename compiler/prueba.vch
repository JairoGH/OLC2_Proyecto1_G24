fn main() { #
    mut a := 10;
    mut b := 20;
    mut c := a + b;

    print("Resultado:", c);

    if c > 15 {
        println("Es mayor a 15");
    } else {
        println("Es menor o igual a 15");
    }

    mut saludo := "Hola";
    saludo += " Mundo";

    println(saludo);
}
